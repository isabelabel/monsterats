# Turso (libSQL) — create a DB at https://turso.tech and use:
#   turso db show <name>   # URL
#   turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Local file DB (no token): uncomment and point to a path under ./data
# TURSO_DATABASE_URL=file:./data/local.db
# TURSO_AUTH_TOKEN=

# Auth — generate a long random string for production (min 32 chars)
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Public URL of the app (no trailing slash). Must match where users open the site.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: object storage for images (works from Render, Docker, or local).
# If unset, files go to ./data/uploads (ephemeral on many hosts unless you use a disk).
# BLOB_READ_WRITE_TOKEN=

# Cloudflare R2 (recommended): direct-to-R2 uploads via presigned URLs.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Public base URL that serves `/${key}` (e.g. your custom domain like https://cdn.example.com)
# R2_PUBLIC_BASE_URL=

# Docker Compose profile `prod`: same variables in a root `.env` (never commit).
