# PostgreSQL (required). Local example matches docker-compose.yml:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/monsterats

# Auth — generate a long random string for production (min 32 chars)
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Public URL of the app (no trailing slash). Must match where users open the site.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Vercel Blob read-write token. Required on Vercel for image uploads (check-ins, avatars, covers).
# On a VPS with a persistent disk, leave unset to store files under ./data/uploads
# BLOB_READ_WRITE_TOKEN=

# --- Docker Compose profile `prod` (VPS / LAN, see DEPLOY.md)
# Put the same BETTER_AUTH_* / NEXT_PUBLIC_* / optional BLOB_* in a root `.env` file
# on the server (never commit). Compose reads `.env` for variable substitution.
